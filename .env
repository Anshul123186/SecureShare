SECURESHARE_SECRET_KEY=change-this-to-a-random-long-string
# 32-byte AES-256 key in hex (64 hex characters)
SECURESHARE_FILE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SQLite example (local file)
SECURESHARE_DATABASE_URI=sqlite:///secureshare.db

# Directory on disk where encrypted files are stored
SECURESHARE_STORAGE_DIR=storage

# Environment: development or production
FLASK_ENV=development
